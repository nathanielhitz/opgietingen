# Scraper-pipeline (scripts/scrape-events.ts via src/lib/scraper.ts)
# Kopieer naar .env voor lokaal draaien; in CI als GitHub Actions secrets.

# Firecrawl: ophalen als markdown + structured extraction — https://firecrawl.dev
FIRECRAWL_API_KEY=

# Claude API: fallback-extractie (claude-haiku-4-5) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optioneel: basis-URL voor canonicals/sitemap (default https://opgietingen.nl)
# NEXT_PUBLIC_SITE_URL=
